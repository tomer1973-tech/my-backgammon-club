// Backgammon Tournament Platform — Prisma Schema v3
//
// Auth:    Supabase handles email/password. supabaseUid links our row to auth.users.
// Roles:   Stored in Player.role — checked in Server Actions and middleware.
// Stats:   Cached on TournamentMember (points/wins/losses), updated atomically
//          in a $transaction with every match completion.
// FKs:     Match/MatchGame use TournamentMember.id for player refs (guest-safe).
// Matches: A Match is the top-level contest (race to N points).
//          MatchGames are individual games within the match.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN               // Full platform access
  TOURNAMENT_MANAGER  // Create and manage own tournaments
  PLAYER              // Join tournaments, record games
}

enum GameType {
  NORMAL      // Standard win            — ×1
  GAMMON      // Loser bore off nothing  — ×2
  BACKGAMMON  // Loser had checkers on bar/in home — ×3
}

enum TournamentFormat {
  ROUND_ROBIN
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  SWISS
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MemberRole {
  ORGANIZER
  PARTICIPANT
}

enum FollowRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum MatchStatus {
  PENDING    // Scheduled, not yet started
  ACTIVE     // In progress
  COMPLETED  // Match over, winner decided
}

enum LiveGameStatus {
  PLAYING
  FINISHED
}

enum OpeningType {
  RUNNING_GAME    // Both sides racing off the board
  BLITZ           // Aggressive prime-building / hitting
  PRIME_VS_PRIME  // Both sides building primes
  BACK_GAME       // One side deliberately falls behind
  HOLDING_GAME    // Anchor strategy (bar-point or opponent's 5-point)
  ANCHOR_GAME     // Deep anchor on opponent's home board
  CUSTOM          // Other / annotated by note
}

// ─────────────────────────────────────────────────────────────────────────────
// PLAYER
// ─────────────────────────────────────────────────────────────────────────────

model Player {
  id          String   @id @default(uuid())
  supabaseUid String   @unique @map("supabase_uid")
  email       String   @unique
  name        String
  role        UserRole @default(PLAYER)
  avatarUrl   String?  @map("avatar_url")
  bio         String?  @map("bio")
  isPrivate    Boolean  @default(false) @map("is_private")
  appearOffline Boolean @default(false) @map("appear_offline")
  isSuspended  Boolean  @default(false) @map("is_suspended")
  quickWins    Int      @default(0)     @map("quick_wins")
  quickLosses  Int      @default(0)     @map("quick_losses")
  rating       Int      @default(1500)  @map("rating")       // ELO-style skill rating, ranked 1-on-1 matches only
  ratedGames   Int      @default(0)     @map("rated_games")  // count of completed ranked matches (provisional indicator)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  memberships        TournamentMember[]
  createdTournaments Tournament[]       @relation("TournamentCreator")
  recordedGames      Game[]             @relation("GameRecorder")
  recordedMatches    Match[]            @relation("MatchRecorder")

  following          Follow[]             @relation("Follower")
  followers          Follow[]             @relation("Following")
  likedMatches       MatchLike[]
  ownedGroups        FriendGroup[]        @relation("GroupCreator")
  groupMemberships   FriendGroupMember[]
  followRequestsSent     FollowRequest[]  @relation("FollowRequestFrom")
  followRequestsReceived FollowRequest[]  @relation("FollowRequestTo")
  challengesSent         Challenge[]      @relation("ChallengeFrom")
  challengesReceived     Challenge[]      @relation("ChallengeTo")
  matchmakingTicket      MatchmakingTicket?
  messagesSent           Message[]        @relation("MessageFrom")
  messagesReceived       Message[]        @relation("MessageTo")

  @@index([rating])
  @@map("players")
}

// ─────────────────────────────────────────────────────────────────────────────
// TOURNAMENT
// ─────────────────────────────────────────────────────────────────────────────

model Tournament {
  id           String           @id @default(uuid())
  name         String
  description  String?
  location     String?
  code         String           @unique
  format       TournamentFormat @default(ROUND_ROBIN)
  status       TournamentStatus @default(DRAFT)
  pointsPerWin Int              @default(1) @map("points_per_win")
  matchLength  Int?             @map("match_length")
  maxPlayers   Int?             @map("max_players")
  startDate    DateTime?        @map("start_date")
  createdById  String           @map("created_by")
  groupId      String?          @map("group_id")
  isPrivate    Boolean          @default(false) @map("is_private")
  isSystem     Boolean          @default(false) @map("is_system") // hidden singleton tournament backing 1-on-1 friendly challenges
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt      @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")
  archivedAt   DateTime?        @map("archived_at")

  createdBy Player             @relation("TournamentCreator", fields: [createdById], references: [id])
  group     FriendGroup?       @relation("GroupTournaments", fields: [groupId], references: [id], onDelete: SetNull)
  members   TournamentMember[]
  games     Game[]
  matches   Match[]

  @@index([createdById])
  @@index([status])
  @@index([groupId])
  @@map("tournaments")
}

// ─────────────────────────────────────────────────────────────────────────────
// TOURNAMENT MEMBER
// ─────────────────────────────────────────────────────────────────────────────

model TournamentMember {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  playerId     String?    @map("player_id")
  guestName    String?    @map("guest_name")
  memberRole   MemberRole @default(PARTICIPANT) @map("member_role")
  points       Int        @default(0)  // tournament points (wins × pointsPerWin)
  wins         Int        @default(0)
  losses       Int        @default(0)
  joinedAt     DateTime   @default(now()) @map("joined_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player?    @relation(fields: [playerId], references: [id], onDelete: SetNull)

  // Legacy standalone game relations
  gamesWon  Game[] @relation("GameWinner")
  gamesLost Game[] @relation("GameLoser")

  // Match relations
  player1Matches   Match[]     @relation("MatchPlayer1")
  player2Matches   Match[]     @relation("MatchPlayer2")
  wonMatches       Match[]     @relation("MatchWinner")
  ownedCubeMatches Match[]     @relation("MatchCubeOwner")
  wonMatchGames    MatchGame[] @relation("MatchGameWinner")
  lostMatchGames   MatchGame[] @relation("MatchGameLoser")

  @@unique([tournamentId, playerId], name: "unique_member_per_tournament")
  @@index([tournamentId])
  @@index([playerId])
  @@map("tournament_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// MATCH
// The top-level contest between two players (race to targetScore match points).
//
// Scoring:
//   Each game within the match awards: cubeValue × gameTypeMultiplier points.
//   (NORMAL×1, GAMMON×2, BACKGAMMON×3)
//   First player to reach targetScore wins the match.
//
// Cube state:
//   cubeValue    — current accepted cube value (1|2|4|8|16|32|64)
//   cubeOwnerId  — null = center (either may double); set = only owner may double next
//   After each game completes, cube resets to center (value=1, owner=null).
//
// Standings cache:
//   On match completion a $transaction increments winner.wins, winner.points,
//   and loser.losses on TournamentMember.
// ─────────────────────────────────────────────────────────────────────────────

model Match {
  id           String      @id @default(uuid())
  tournamentId String      @map("tournament_id")
  player1Id    String?     @map("player1_id")   // TournamentMember.id — null = not yet decided (bracket slot awaiting a winner)
  player2Id    String?     @map("player2_id")   // TournamentMember.id — null = not yet decided
  targetScore  Int         @map("target_score")
  player1Score Int         @default(0) @map("player1_score")
  player2Score Int         @default(0) @map("player2_score")
  cubeValue    Int         @default(1) @map("cube_value")   // accepted value
  cubeOwnerId  String?     @map("cube_owner_id")            // null = center
  status       MatchStatus @default(PENDING)
  winnerId     String?     @map("winner_id")
  round        Int?        @map("round")          // round number for auto-scheduled formats (round robin / swiss / brackets); null = ad-hoc match
  bracket       String?    @map("bracket")        // 'WINNERS' | 'LOSERS' | 'GRAND_FINAL' for elimination formats; null = non-bracket
  bracketSlot   Int?       @map("bracket_slot")   // position of this match within its round (top-to-bottom)
  nextMatchId   String?    @map("next_match_id")  // bracket: match the WINNER advances into
  nextMatchSlot Int?       @map("next_match_slot")// which player slot (1 or 2) the winner fills in nextMatch
  openingType  OpeningType? @map("opening_type")
  notes        String?
  scheduledAt  DateTime?   @map("scheduled_at")   // null = start immediately
  startedAt    DateTime?   @map("started_at")
  completedAt  DateTime?   @map("completed_at")
  duration     Int?        // seconds, filled on completion
  recordedById String      @map("recorded_by")   // Player.id
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt      @map("updated_at")

  tournament Tournament        @relation(fields: [tournamentId],  references: [id], onDelete: Cascade)
  player1    TournamentMember? @relation("MatchPlayer1",   fields: [player1Id],   references: [id], onDelete: SetNull)
  player2    TournamentMember? @relation("MatchPlayer2",   fields: [player2Id],   references: [id], onDelete: SetNull)
  winner     TournamentMember? @relation("MatchWinner",    fields: [winnerId],    references: [id], onDelete: SetNull)
  cubeOwner  TournamentMember? @relation("MatchCubeOwner", fields: [cubeOwnerId], references: [id], onDelete: SetNull)
  recordedBy Player            @relation("MatchRecorder",  fields: [recordedById],references: [id], onDelete: Restrict)
  nextMatch  Match?            @relation("BracketAdvance", fields: [nextMatchId], references: [id], onDelete: SetNull)
  prevMatches Match[]          @relation("BracketAdvance")
  games      MatchGame[]
  likes      MatchLike[]
  liveGame   LiveGame?

  @@index([tournamentId, status])
  @@index([tournamentId, createdAt(sort: Desc)])
  @@index([player1Id])
  @@index([player2Id])
  @@map("matches")
}

// ─────────────────────────────────────────────────────────────────────────────
// LIVE GAME
// Live (in-browser) board state for an online backgammon game within a Match.
// One row per Match — overwritten/reset for each successive game in the match.
// Synced between players via Supabase Realtime broadcast on channel
// `live-game-{id}`; this row is the source of truth on reconnect.
// ─────────────────────────────────────────────────────────────────────────────

model LiveGame {
  id            String         @id @default(uuid())
  matchId       String         @unique @map("match_id")
  gameNumber    Int            @map("game_number")
  board         Json                                      // Board (points/bar/borneOff)
  turnStartBoard Json          @map("turn_start_board")   // Board at the start of the current turn (for Undo)
  currentPlayer String         @map("current_player")     // 'white' | 'black'
  dice          Json?                                      // Dice ([number, number]) | null
  movesPlayed   Json           @default("[]") @map("moves_played") // Move[]
  cubeValue     Int            @default(1) @map("cube_value")
  cubeOwner     String?        @map("cube_owner")          // 'white' | 'black' | null
  doubleOffer   String?        @map("double_offer")        // 'white' | 'black' | null
  player1Color  String         @map("player1_color")       // 'white' | 'black'
  status        LiveGameStatus @default(PLAYING)
  winner        String?                                    // 'white' | 'black' | null
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt      @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("live_games")
}

// ─────────────────────────────────────────────────────────────────────────────
// MATCH GAME
// One individual game within a Match.
// Points awarded = cubeValue × gameTypeMultiplier.
// ─────────────────────────────────────────────────────────────────────────────

model MatchGame {
  id            String   @id @default(uuid())
  matchId       String   @map("match_id")
  gameNumber    Int      @map("game_number")  // 1-based, auto-incremented
  winnerId      String   @map("winner_id")    // TournamentMember.id
  loserId       String   @map("loser_id")     // TournamentMember.id
  cubeValue     Int      @map("cube_value")
  gameType      GameType @default(NORMAL) @map("game_type")
  pointsAwarded Int      @map("points_awarded")  // cube × gameTypeMultiplier
  createdAt     DateTime @default(now()) @map("created_at")

  match  Match            @relation(fields: [matchId],   references: [id], onDelete: Cascade)
  winner TournamentMember @relation("MatchGameWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  loser  TournamentMember @relation("MatchGameLoser",  fields: [loserId],  references: [id], onDelete: Restrict)

  @@index([matchId, gameNumber])
  @@map("match_games")
}

// ─────────────────────────────────────────────────────────────────────────────
// GAME (legacy — standalone games outside match context)
// ─────────────────────────────────────────────────────────────────────────────

model Game {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  winnerId     String   @map("winner_id")
  loserId      String   @map("loser_id")
  multiplier   Int      @default(1)
  gameType     GameType @default(NORMAL) @map("game_type")
  points       Int
  notes        String?
  recordedById String   @map("recorded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  tournament Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  winner     TournamentMember @relation("GameWinner", fields: [winnerId], references: [id], onDelete: Restrict)
  loser      TournamentMember @relation("GameLoser",  fields: [loserId],  references: [id], onDelete: Restrict)
  recordedBy Player           @relation("GameRecorder", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([tournamentId, createdAt(sort: Desc)])
  @@index([winnerId])
  @@index([loserId])
  @@map("games")
}

// ─────────────────────────────────────────────────────────────────────────────
// SOCIAL FEATURES
// ─────────────────────────────────────────────────────────────────────────────

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    Player   @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   Player   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model MatchLike {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  playerId  String   @map("player_id")
  createdAt DateTime @default(now()) @map("created_at")
  match     Match    @relation(fields: [matchId],  references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([matchId, playerId])
  @@index([matchId])
  @@map("match_likes")
}

model FriendGroup {
  id          String   @id @default(uuid())
  name        String
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")
  createdBy    Player        @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      FriendGroupMember[]
  tournaments  Tournament[]  @relation("GroupTournaments")
  @@index([createdById])
  @@map("friend_groups")
}

model FriendGroupMember {
  id       String      @id @default(uuid())
  groupId  String      @map("group_id")
  playerId String      @map("player_id")
  joinedAt DateTime    @default(now()) @map("joined_at")
  group    FriendGroup @relation(fields: [groupId],  references: [id], onDelete: Cascade)
  player   Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  @@unique([groupId, playerId])
  @@index([groupId])
  @@map("friend_group_members")
}

model FollowRequest {
  id        String              @id @default(uuid())
  fromId    String              @map("from_id")
  toId      String              @map("to_id")
  status    FollowRequestStatus @default(PENDING)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt      @map("updated_at")
  from      Player              @relation("FollowRequestFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Player              @relation("FollowRequestTo",   fields: [toId],   references: [id], onDelete: Cascade)
  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@map("follow_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHALLENGE — invite a mutual-follow ("friend") to a 1-on-1 live game.
// On accept, a Match + LiveGame is created inside the hidden singleton
// "Friendly Matches" system tournament, reusing all existing live-game infra.
// ─────────────────────────────────────────────────────────────────────────────

model Challenge {
  id           String          @id @default(uuid())
  fromId       String          @map("from_id")
  toId         String          @map("to_id")
  status       ChallengeStatus @default(PENDING)
  tournamentId String?         @map("tournament_id")
  matchId      String?         @map("match_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt      @map("updated_at")

  from Player @relation("ChallengeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Player @relation("ChallengeTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@index([toId, status])
  @@index([fromId, status])
  @@map("challenges")
}

model Message {
  id        String    @id @default(uuid())
  fromId    String    @map("from_id")
  toId      String    @map("to_id")
  body      String
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  from Player @relation("MessageFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Player @relation("MessageTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@index([toId, createdAt])
  @@index([fromId, toId, createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// MATCHMAKING — rated 1-on-1 queue. Players queue with a rating snapshot;
// any client's poll may pair two WAITING tickets within tolerance and create
// the Match + LiveGame (same hidden "Friendly Matches" tournament as
// Challenge). One ticket per player, enforced by the unique playerId.
// ─────────────────────────────────────────────────────────────────────────────

enum MatchmakingStatus {
  WAITING
  MATCHED
  CANCELLED
}

model MatchmakingTicket {
  id            String            @id @default(uuid())
  playerId      String            @unique @map("player_id")
  rating        Int                                          // snapshot at queue time
  status        MatchmakingStatus @default(WAITING)
  tournamentId  String?           @map("tournament_id")
  matchId       String?           @map("match_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt      @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("matchmaking_tickets")
}
